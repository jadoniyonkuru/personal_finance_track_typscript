{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./",
    "rootDir": "./",
    "declaration": false,
    "moduleResolution": "bundler",
    "ignoreDeprecations": "6.0"
  },
  "include": ["app.ts"],
  "exclude": ["node_modules"]
}